diff --git a/services/dashboard/src/lib/export.ts b/services/dashboard/src/lib/export.ts
index 3be9df43..65eabac6 100644
--- a/services/dashboard/src/lib/export.ts
+++ b/services/dashboard/src/lib/export.ts
@@ -149,3 +149,248 @@ export function generateFilename(meeting: Meeting, extension: string): string {
   const id = meeting.platform_specific_id.replace(/[^a-zA-Z0-9]/g, "-");
   return `transcript-${date}-${id}.${extension}`;
 }
+
+// ─── Insights export (Decisions & Anthology) ──────────────────────────────────
+
+export interface ExportDecisionItem {
+  type: string;
+  summary: string;
+  speaker?: string;
+  confidence?: number;
+}
+
+export interface ExportAnthologyItem {
+  type: string;
+  summary: string;
+  speaker?: string;
+  confidence?: number;
+  entities: Array<{ type: string; label: string; id: string }>;
+}
+
+export interface ExportSummaryData {
+  lede: string;
+  theme: string;
+}
+
+const TYPE_LABELS: Record<string, string> = {
+  decision: "Decision",
+  action_item: "Action Item",
+  key_insight: "Key Insight",
+  commitment: "Commitment",
+  architecture_statement: "Architecture Statement",
+};
+
+function typeLabel(t: string): string {
+  return TYPE_LABELS[t] ?? t;
+}
+
+function fmtMeetingMeta(meeting: Meeting): string {
+  let out = `Meeting ID: ${meeting.platform_specific_id}\n`;
+  if (meeting.start_time) {
+    out += `Date: ${format(new Date(meeting.start_time), "PPPp")}\n`;
+  }
+  if (meeting.data?.participants?.length) {
+    out += `Participants: ${meeting.data.participants.join(", ")}\n`;
+  }
+  return out;
+}
+
+export function exportDecisionsToTxt(meeting: Meeting, items: ExportDecisionItem[]): string {
+  let out = "=".repeat(60) + "\n";
+  out += "LIVE DECISIONS\n";
+  out += "=".repeat(60) + "\n\n";
+  out += fmtMeetingMeta(meeting);
+  out += "\n" + "-".repeat(60) + "\n";
+  out += `ITEMS (${items.length})\n`;
+  out += "-".repeat(60) + "\n\n";
+
+  if (items.length === 0) {
+    out += "No items recorded.\n";
+  } else {
+    for (const item of items) {
+      out += `[${typeLabel(item.type)}]\n`;
+      out += `${item.summary}\n`;
+      const meta: string[] = [];
+      if (item.speaker) meta.push(`Speaker: ${item.speaker}`);
+      if (item.confidence !== undefined) meta.push(`Confidence: ${Math.round(item.confidence * 100)}%`);
+      if (meta.length) out += meta.join("   ") + "\n";
+      out += "\n";
+    }
+  }
+
+  out += "=".repeat(60) + "\n";
+  out += `Exported on ${format(new Date(), "PPPp")}\n`;
+  out += "Generated by Vexa Dashboard\n";
+  out += "=".repeat(60) + "\n";
+  return out;
+}
+
+export function exportDecisionsToJson(meeting: Meeting, items: ExportDecisionItem[]): string {
+  return JSON.stringify({
+    meeting: {
+      id: meeting.id,
+      platform: meeting.platform,
+      platform_specific_id: meeting.platform_specific_id,
+      status: meeting.status,
+      start_time: meeting.start_time,
+      end_time: meeting.end_time,
+      participants: meeting.data?.participants || [],
+    },
+    decisions: items.map((i) => ({
+      type: i.type,
+      summary: i.summary,
+      ...(i.speaker !== undefined && { speaker: i.speaker }),
+      ...(i.confidence !== undefined && { confidence: i.confidence }),
+    })),
+    exported_at: new Date().toISOString(),
+  }, null, 2);
+}
+
+export function exportDecisionsToMd(meeting: Meeting, items: ExportDecisionItem[]): string {
+  let out = "# Live Decisions\n\n";
+  out += `**Meeting ID:** ${meeting.platform_specific_id}  \n`;
+  if (meeting.start_time) out += `**Date:** ${format(new Date(meeting.start_time), "PPPp")}  \n`;
+  if (meeting.data?.participants?.length) out += `**Participants:** ${meeting.data.participants.join(", ")}  \n`;
+  out += "\n---\n\n## Items\n\n";
+
+  if (items.length === 0) {
+    out += "*No items recorded.*\n";
+  } else {
+    for (const item of items) {
+      out += `### ${typeLabel(item.type)}\n\n`;
+      out += `${item.summary}\n\n`;
+      const meta: string[] = [];
+      if (item.speaker) meta.push(`Speaker: ${item.speaker}`);
+      if (item.confidence !== undefined) meta.push(`Confidence: ${Math.round(item.confidence * 100)}%`);
+      if (meta.length) out += `*${meta.join(" · ")}*\n\n`;
+    }
+  }
+
+  out += `---\n*Exported on ${format(new Date(), "PPPp")} · Generated by Vexa Dashboard*\n`;
+  return out;
+}
+
+export function exportAnthologyToTxt(
+  meeting: Meeting,
+  items: ExportAnthologyItem[],
+  summary: ExportSummaryData | null,
+): string {
+  let out = "=".repeat(60) + "\n";
+  out += "ANTHOLOGY\n";
+  out += "=".repeat(60) + "\n\n";
+  out += fmtMeetingMeta(meeting);
+
+  if (summary) {
+    out += "\n" + "-".repeat(60) + "\n";
+    out += "SUMMARY\n";
+    out += "-".repeat(60) + "\n\n";
+    out += `Theme: ${summary.theme}\n\n`;
+    out += `${summary.lede}\n`;
+  }
+
+  out += "\n" + "-".repeat(60) + "\n";
+  out += `ITEMS (${items.length})\n`;
+  out += "-".repeat(60) + "\n\n";
+
+  if (items.length === 0) {
+    out += "No items recorded.\n";
+  } else {
+    for (const item of items) {
+      out += `[${typeLabel(item.type)}]\n`;
+      out += `${item.summary}\n`;
+      const meta: string[] = [];
+      if (item.speaker) meta.push(`Speaker: ${item.speaker}`);
+      if (item.confidence !== undefined) meta.push(`Confidence: ${Math.round(item.confidence * 100)}%`);
+      if (meta.length) out += meta.join("   ") + "\n";
+      if (item.entities?.length) {
+        out += `Entities: ${item.entities.map((e) => `${e.label} (${e.type})`).join(", ")}\n`;
+      }
+      out += "\n";
+    }
+  }
+
+  out += "=".repeat(60) + "\n";
+  out += `Exported on ${format(new Date(), "PPPp")}\n`;
+  out += "Generated by Vexa Dashboard\n";
+  out += "=".repeat(60) + "\n";
+  return out;
+}
+
+export function exportAnthologyToJson(
+  meeting: Meeting,
+  items: ExportAnthologyItem[],
+  summary: ExportSummaryData | null,
+): string {
+  return JSON.stringify({
+    meeting: {
+      id: meeting.id,
+      platform: meeting.platform,
+      platform_specific_id: meeting.platform_specific_id,
+      status: meeting.status,
+      start_time: meeting.start_time,
+      end_time: meeting.end_time,
+      participants: meeting.data?.participants || [],
+    },
+    summary: summary ?? null,
+    items: items.map((i) => ({
+      type: i.type,
+      summary: i.summary,
+      ...(i.speaker !== undefined && { speaker: i.speaker }),
+      ...(i.confidence !== undefined && { confidence: i.confidence }),
+      entities: i.entities ?? [],
+    })),
+    exported_at: new Date().toISOString(),
+  }, null, 2);
+}
+
+export function exportAnthologyToMd(
+  meeting: Meeting,
+  items: ExportAnthologyItem[],
+  summary: ExportSummaryData | null,
+): string {
+  let out = "# Anthology\n\n";
+  out += `**Meeting ID:** ${meeting.platform_specific_id}  \n`;
+  if (meeting.start_time) out += `**Date:** ${format(new Date(meeting.start_time), "PPPp")}  \n`;
+  if (meeting.data?.participants?.length) out += `**Participants:** ${meeting.data.participants.join(", ")}  \n`;
+  out += "\n---\n\n";
+
+  if (summary) {
+    out += "## Summary\n\n";
+    out += `**${summary.theme}**\n\n`;
+    out += `${summary.lede}\n\n---\n\n`;
+  }
+
+  out += "## Items\n\n";
+  if (items.length === 0) {
+    out += "*No items recorded.*\n";
+  } else {
+    for (const item of items) {
+      out += `### ${typeLabel(item.type)}\n\n`;
+      out += `${item.summary}\n\n`;
+      if (item.speaker) out += `*Speaker: ${item.speaker}*  \n`;
+      if (item.entities?.length) {
+        out += `**Entities:** ${item.entities.map((e) => `\`${e.label}\` (${e.type})`).join(", ")}  \n`;
+      }
+      out += "\n";
+    }
+  }
+
+  out += `---\n*Exported on ${format(new Date(), "PPPp")} · Generated by Vexa Dashboard*\n`;
+  return out;
+}
+
+export function generateDecisionsFilename(meeting: Meeting, extension: string): string {
+  const date = meeting.start_time
+    ? format(new Date(meeting.start_time), "yyyy-MM-dd")
+    : format(new Date(), "yyyy-MM-dd");
+  const id = meeting.platform_specific_id.replace(/[^a-zA-Z0-9]/g, "-");
+  return `decisions-${date}-${id}.${extension}`;
+}
+
+export function generateAnthologyFilename(meeting: Meeting, extension: string): string {
+  const date = meeting.start_time
+    ? format(new Date(meeting.start_time), "yyyy-MM-dd")
+    : format(new Date(), "yyyy-MM-dd");
+  const id = meeting.platform_specific_id.replace(/[^a-zA-Z0-9]/g, "-");
+  return `anthology-${date}-${id}.${extension}`;
+}
