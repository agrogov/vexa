+# Mapping stability constants
+MIN_SPEECH_BURST_MS = 350
+SHORT_SILENCE_GAP_MS = 700
+MIN_MEANINGFUL_OVERLAP_MS = 50
+MULTIPLE_AMBIGUITY_RATIO = 1.2
+FALLBACK_CONTEXT_WINDOW_MS = 15000
+FALLBACK_DOMINANCE_RATIO = 2.0
